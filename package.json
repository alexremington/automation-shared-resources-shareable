{
  "name": "automation-shared-resources",
  "version": "0.1.0",
  "private": true,
  "description": "Shared UI, test, and workflow resources for managed Automation Projects apps.",
  "scripts": {
    "check": "node scripts/check.js && node scripts/check-platform.js && node scripts/check-hume-design.js && tsc --noEmit",
    "check:features": "node scripts/check-feature-manifest.js --all",
    "check:hume": "node scripts/check-hume-design.js",
    "feature:new": "node scripts/feature-new.js",
    "pipeline": "node scripts/managed-app-pipeline.js",
    "verify:fast": "node scripts/managed-app-pipeline.js --tier fast",
    "verify:smoke": "node scripts/managed-app-pipeline.js --tier smoke",
    "verify:release": "node scripts/managed-app-pipeline.js --tier release"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
